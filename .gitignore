# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Testing
.pytest_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Streamlit
.streamlit/secrets.toml

# Temp/output files
*.sup
*.mkv
*.ass

# Node / npm workspaces
node_modules/
.npm/

# Next.js
.next/
out/
next-env.d.ts

# Vite (desktop frontend build output)
apps/desktop/dist/

# Web app: ffmpeg.wasm runtime files staged from node_modules.
# Regenerated by `apps/web/scripts/setup-ffmpeg-assets.sh`.  Too large
# for git history (~31MB wasm) and trivially restorable from npm deps.
apps/web/public/ffmpeg/

# Spike artifacts: regenerated by running the scripts, not source.
# Keep the visual PNGs (reference / browser / diff) committed as
# evidence of the spike outcome; drop the multi-MB raw RGBA buffers
# and the per-run stats file.
spike/*/reference.bin
spike/*/browser.bin
spike/*/stats.txt
spike/*/frame.html
spike/*/fonts/

# Real Netflix subtitle captures from capture-kit.js (fetchSample →
# netflix-<lang>.vtt / -<profile>.<ext>).  Full copyrighted subtitle
# documents — kept on disk as local parser-validation data, NOT in git
# history.  The tiny hand-trimmed head excerpts (sample-subs-*-real.vtt)
# ARE committed as test fixtures.
spike/netflix/netflix-*.vtt
spike/netflix/netflix-*.ttml
spike/netflix/netflix-*.txt

# Bundled resources (3c) — fetched at build time via scripts/setup_bundle.sh.
# Too large for git history (~600 MB total: fonts ~45 MB, Python runtime +
# venv ~250 MB, Chromium ~170 MB).  Each subdir has its own fetch step.
apps/desktop/src-tauri/resources/fonts/
apps/desktop/src-tauri/resources/python/
apps/desktop/src-tauri/resources/playwright-browsers/

# Claude Code per-project state (settings, scheduled-tasks lock).
.claude/
