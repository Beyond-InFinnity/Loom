{
  "name": "@loom/extension",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Loom browser extension — dual subs with romanization on YouTube, Netflix, iQIYI, and WeTV.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build -b firefox --mode production",
    "build:firefox": "wxt build -b firefox --mode production",
    "build:firefox:dev": "wxt build -b firefox --mode development",
    "build:firefox:prod": "wxt build -b firefox --mode production",
    "build:chrome": "wxt build -b chrome --mode production",
    "build:chrome:dev": "wxt build -b chrome --mode development",
    "build:chrome:prod": "wxt build -b chrome --mode production",
    "zip": "wxt zip -b firefox --mode production",
    "icons": "python3 scripts/gen-icons.py",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@loom/api-client": "*",
    "@loom/orthography-tables": "*",
    "react": "^19.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.293",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@wxt-dev/module-react": "^1.1.3",
    "typescript": "~5.8.3",
    "vitest": "^4.1.6",
    "wxt": "^0.20.26"
  }
}
