{
  "name": "loom-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:desktop": "npm --workspace apps/desktop run build",
    "build:web": "npm --workspace apps/web run build",
    "dev:desktop": "npm --workspace apps/desktop run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "tauri:build": "npm --workspace apps/desktop run tauri build",
    "tauri:dev": "npm --workspace apps/desktop run tauri dev",
    "gen:api-client": "npm --workspace packages/api-client run generate"
  }
}
