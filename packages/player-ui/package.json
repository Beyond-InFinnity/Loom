{
  "name": "@loom/player-ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Host-agnostic Loom caption UI \u2014 overlay, annotation ruby, definition card plumbing, i18n \u2014 consumed by the browser extension and the native Loom Player WebViews (MOBILE_ROADMAP.md).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./seams": "./src/seams/index.ts",
    "./host": "./src/host.ts",
    "./components/annotated-text": "./src/components/annotated-text.tsx",
    "./components/definition-card": "./src/components/definition-card.tsx",
    "./*": "./src/*.ts"
  },
  "dependencies": {
    "@loom/orthography-tables": "*",
    "@loom/api-client": "*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "~5.8.3"
