{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pip install --upgrade pip && pip install -r requirements-web.txt",
    "watchPatterns": [
      "loom_api/**",
      "loom_core/**",
      "requirements-web.txt",
      "Procfile",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "gunicorn loom_api.web:app -k uvicorn_worker.UvicornWorker --workers 1 --max-requests 500 --max-requests-jitter 50 --timeout 120 --bind 0.0.0.0:$PORT",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
